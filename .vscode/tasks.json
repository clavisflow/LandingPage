{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "next: dev",
      "type": "shell",
      "command": "C:\\Program Files\\nodejs\\corepack.cmd",
      "args": [
        "pnpm",
        "dev",
        "--hostname",
        "127.0.0.1",
        "--port",
        "3000",
        "--webpack"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "nextjs",
        "pattern": [
          {
            "regexp": "^(.*)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Ready in.*"
        }
      }
    }
  ]
}
